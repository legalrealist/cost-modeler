# Serve built files from dist/
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Already inside dist/ — stop
  RewriteRule ^dist/ - [L]

  # Static assets — proxy to dist/assets/
  RewriteRule ^(assets/.*)$ dist/$1 [L]

  # Everything else — SPA fallback to dist/index.html
  RewriteRule ^.*$ dist/index.html [L]
</IfModule>
